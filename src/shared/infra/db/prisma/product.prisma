model Product {
  id              String   @id @default(uuid())
  name            String
  category        String

  minimumStock    Int
  expirationDate  DateTime

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inventories     Inventory[]
  stockMovements  StockMovement[]
  deliveries      Delivery[]

  @@map("products")
}