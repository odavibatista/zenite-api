model Delivery {
  id             String         @id @default(uuid())

  productId      String

  quantity       Int

  expectedDate   DateTime
  deliveredDate  DateTime?

  status         DeliveryStatus

  createdAt      DateTime @default(now())

  product         Product @relation(fields: [productId], references: [id])

  @@map("deliveries")
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  LATE
  CANCELLED
}
