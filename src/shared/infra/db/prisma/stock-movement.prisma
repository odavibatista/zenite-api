model StockMovement {
  id            String       @id @default(uuid())

  productId     String
  warehouseId   String

  movementType  MovementType

  quantity      Int

  reason        String?

  createdAt     DateTime @default(now())

  product        Product   @relation(fields: [productId], references: [id])
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("stock_movements")
}

enum MovementType {
  INBOUND
  OUTBOUND
  LOSS
  ADJUSTMENT
}